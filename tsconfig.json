{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "outDir": "./lib",
    "rootDir": "."
  },
  "include": ["./*.ts"],
  "exclude": ["node_modules", "dist", "lib", "dist-test", "*.test.ts", "tsup.config.ts"]
}
